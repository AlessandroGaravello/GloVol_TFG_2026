rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== HELPERS ==========
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isAuth() && userData().role == 'admin';
    }
    function isModerator() {
      return isAuth() && userData().role == 'moderator';
    }
    function isAdminOrModerator() {
      return isAdmin() || isModerator();
    }
    function isVerified() {
      return isAuth() && userData().isVerified == true;
    }
    function hasWarCrimesAccess() {
      return isAuth() && userData().warCrimesAccess == true;
    }
    function canPostWarCrimes() {
      return isVerified() &&
        get(/databases/$(database)/documents/verifiedProfiles/$(request.auth.uid)).data.canPostWarCrimes == true;
    }

    // ========== USUARIOS ==========
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdminOrModerator();
      allow delete: if isAdminOrModerator();

      // Subcolecciones de seguimiento
      match /followers/{followerId} {
        allow read: if true;
        allow write: if isAuth();
      }
      match /following/{followingId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }

    // ========== SOLICITUDES DE VERIFICACIÓN ==========
    match /verificationRequests/{requestId} {
      // Los administradores pueden leer todas las solicitudes (para el panel)
      allow read: if isAdminOrModerator();
      // Los usuarios normales solo pueden leer sus propias solicitudes
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdminOrModerator();
      allow delete: if false;
    }

    // ========== PERFILES VERIFICADOS ==========
    match /verifiedProfiles/{userId} {
      allow read: if true;
      allow write: if isAdminOrModerator();
    }

    // ========== CATÁSTROFES ==========
    match /disasters/{disasterId} {
      allow read: if true;
      allow create: if isVerified() || isAdminOrModerator();
      allow update: if isAdminOrModerator();
      allow delete: if isAdminOrModerator();
    }

    // ========== POSTS ==========
    match /posts/{postId} {
      allow read: if resource.data.isWarCrimeReport == false || hasWarCrimesAccess();
      allow create: if isVerified() &&
        (request.resource.data.isWarCrimeReport == false || canPostWarCrimes());
      allow update: if isOwner(resource.data.authorId) || isAdminOrModerator();
      allow delete: if isAdminOrModerator();

      // Subcolección de likes
      match /likes/{userId} {
        allow read: if true;
        allow write: if isAuth();
      }

      // Subcolección de comentarios
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth();
        allow update: if isOwner(resource.data.authorId) || isAdminOrModerator();
        allow delete: if isOwner(resource.data.authorId) || isAdminOrModerator();
      }
    }

    // ========== DONACIONES ==========
    match /donations/{donationId} {
      // Administradores pueden leer todas (para el panel)
      allow read: if isAdminOrModerator();
      // Usuarios solo sus propias donaciones
      allow read: if isOwner(resource.data.donorId);
      allow create: if isAuth() && request.resource.data.donorId == request.auth.uid;
      allow update: if isAdminOrModerator();
      allow delete: if false;
    }

    // ========== VOLUNTARIOS ==========
    match /volunteers/{volunteerId} {
      // Administradores y verificados pueden leer todos (para listados)
      allow read: if isAdminOrModerator() || isVerified();
      // Usuarios pueden leer sus propios registros
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) || isVerified() || isAdminOrModerator();
      allow delete: if isOwner(resource.data.userId) || isAdminOrModerator();
    }

    // ========== REPORTES ==========
    match /reports/{reportId} {
      allow read: if isAdminOrModerator();
      allow create: if isAuth();
      allow update: if isAdminOrModerator();
      allow delete: if false;
    }

    // ========== NOTIFICACIONES ==========
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId);
      allow create: if isAdminOrModerator();
      allow delete: if isOwner(resource.data.userId) || isAdminOrModerator();
    }

    // ========== CRÍMENES DE GUERRA ==========
    match /warCrimeReports/{reportId} {
      allow read: if hasWarCrimesAccess();
      allow create: if canPostWarCrimes();
      allow update: if isAdminOrModerator();
      allow delete: if isAdminOrModerator();
    }

    // ========== MEDIA CONTENT ==========
    match /mediaContent/{mediaId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.uploadedBy == request.auth.uid;
      allow update: if isAdminOrModerator();
      allow delete: if isAdminOrModerator();
    }

    // ========== ADMIN ACTIONS (log) ==========
    match /adminActions/{actionId} {
      allow read: if isAdminOrModerator();
      allow write: if isAdminOrModerator();
    }
  }
}