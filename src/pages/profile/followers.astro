---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import FollowList from '../../components/profile/FollowList';

const uid = Astro.url.searchParams.get('uid') || '';
---
<BaseLayout title="Seguidores" showSidebars={true} currentPath="/profile">
  <div class="max-w-2xl mx-auto">
    <div class="flex items-center gap-3 px-4 py-4 border-b border-zinc-800">
      <a href={`/profile/${uid}`} class="p-1.5 text-zinc-500 hover:text-white transition rounded-lg hover:bg-zinc-900">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/>
        </svg>
      </a>
      <h1 class="text-base font-semibold text-white">Seguidores</h1>
    </div>
    <FollowList userId={uid} mode="followers" client:load />
  </div>
</BaseLayout>
